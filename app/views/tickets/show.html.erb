<header>
  <h1>Ticket</h1>
</header>

<section>
  <p>
    <strong>Name:</strong>
    <%= @ticket.name %>
  </p>

  <p>
    <strong>Seat id seq:</strong>
    <%= @ticket.seat_id_seq %>
  </p>

  <p>
    <strong>Address:</strong>
    <%= @ticket.address %>
  </p>

  <p>
    <strong>Price:</strong>
    <%= @ticket.price %>
  </p>

  <p>
    <strong>Email address:</strong>
    <%= @ticket.email_address %>
  </p>

  <p>
    <strong>Phone:</strong>
    <%= @ticket.phone %>
  </p>
</section>

<footer>
  <% if @ticket.user_id == current_user&.id %>
    <%= link_to 'Edit', edit_ticket_path(@ticket) %>
  <% end %>
  <%= link_to 'Back', tickets_path %>
</footer>
